{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"],
      "@/tailwind": ["./tailwind.config.js"],
      "@/test/*": ["./test/*"],
      "test/*": ["./test/*"]
    }
  },
  "include": [
    "../next-env.d.ts",
    "../src/**/*.ts",
    "../src/**/*.tsx",
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "exclude": [
    "../node_modules"
  ]
}
